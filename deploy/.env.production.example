# Copy to .env next to docker-compose.prod.yml:
#   cp .env.production.example .env

# Public hostname for Nakama (DNS A/AAAA → server IP). Used by Caddy for HTTPS.
NAKAMA_PUBLIC_HOST=nakama.example.com

# Database (Postgres is not exposed publicly; only used on Docker network).
POSTGRES_PASSWORD=change-me-long-random-string

# Nakama client API key — must match VITE_NAKAMA_SERVER_KEY in the frontend build.
SERVER_KEY=change-me-another-long-secret
